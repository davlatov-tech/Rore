fn build_async_page() -> impl Widget {
    let user_profile = create_resource(move || {
        std::thread::sleep(std::time::Duration::from_secs(3));
        "Dvigatel yashin tezligida ishlamoqda! UI qotib qolmadi.".to_string()
    });
    let loading_width = Signal::new(200.0);
    let anim_w = create_tween(loading_width, 1.0, Easing::Bounce);
    let anim_color = create_tween(Signal::new(Color::hex("#3b82f6")), 1.0, Easing::Linear);

    UiBox::new()
        .style(Style {
            flex_direction: FlexDirection::Column,
            gap: Size {
                width: 0.0,
                height: 20.0,
            },
            align_items: Align::Center,
            justify_content: Align::Center,
            height: Val::Percent(100.0),
            ..Default::default()
        })
        .child(
            Suspense::new(user_profile)
                .fallback(move || {
                    loading_width.set(300.0);
                    Box::new(
                        AnimatedBox::new("loader", anim_w, anim_color)
                            .child(Text::new("Kutilmoqda... ⏳").color(Color::WHITE)),
                    )
                })
                .child(|data| {
                    Box::new(
                        UiBox::new()
                            .surface()
                            .corner_radius(20.0)
                            .style(Style {
                                padding: Thickness::all(Val::Px(40.0)),
                                ..Default::default()
                            })
                            .child(Text::new(data).size(20.0)),
                    )
                }),
        )
}

fn main() {
    let renderer_factory =
        move |device: &_, queue: &_, config: &_| -> Box<dyn rore_types::text::TextRenderer> {
            Box::new(TextSystem::new(device, queue, config))
        };
    run(
        RoreEnterpriseApp {},
        RoreConfig::desktop(),
        renderer_factory,
    );
}
